# Supabase (클라이언트·서버 공통)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 서버 전용 — 관리자 API 등에서만 사용. 절대 NEXT_PUBLIC_ 접두사 붙이지 마세요.
# Vercel: Project → Settings → Environment Variables → Production에 동일 이름으로 등록 후 재배포.
SUPABASE_SERVICE_ROLE_KEY=

# 관리자 로그인·x-admin-password 헤더용 (NEXT_PUBLIC_ 이라 클라이언트에 노출됨 — 운영 시 세션 기반 전환 권장)
NEXT_PUBLIC_ADMIN_PASSWORD=

# Vercel: 민감 변수(SUPABASE_SERVICE_ROLE_KEY)는 Production·Preview에만 등록 가능합니다(Sensitive는 development 타깃 불가).
# 설정 후 반드시 재배포해야 런타임에 반영됩니다. CLI: vercel env add SUPABASE_SERVICE_ROLE_KEY production --sensitive
